@model GL.Domain.Entities.BalanceSheetReport
@{
    ViewData["Title"] = "Bảng cân đối kế toán";
}

<div class="container mt-4">
    <h1>Bảng cân đối kế toán (BCĐKT)</h1>
    <p class="text-muted">Kỳ báo cáo: @ViewBag.PeriodCode - Ngày lập: @ViewBag.ReportDate</p>
    <hr />
    
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Tài sản</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên tài khoản</th>
                        <th class="text-end">Số tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var asset in Model.Assets)
                    {
                        <tr>
                            <td>@asset.Code</td>
                            <td>@asset.Name</td>
                            <td class="text-end">@asset.Amount.ToString("N0")</td>
                        </tr>
                    }
                    <tr class="table-primary fw-bold">
                        <td colspan="2">Tổng Tài sản</td>
                        <td class="text-end">@Model.TotalAssets.ToString("N0")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Nợ phải trả</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên tài khoản</th>
                        <th class="text-end">Số tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var liability in Model.Liabilities)
                    {
                        <tr>
                            <td>@liability.Code</td>
                            <td>@liability.Name</td>
                            <td class="text-end">@liability.Amount.ToString("N0")</td>
                        </tr>
                    }
                    <tr class="table-danger fw-bold">
                        <td colspan="2">Tổng Nợ phải trả</td>
                        <td class="text-end">@Model.TotalLiabilities.ToString("N0")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Vốn chủ sở hữu</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên tài khoản</th>
                        <th class="text-end">Số tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var equity in Model.Equities)
                    {
                        <tr>
                            <td>@equity.Code</td>
                            <td>@equity.Name</td>
                            <td class="text-end">@equity.Amount.ToString("N0")</td>
                        </tr>
                    }
                    <tr class="table-success fw-bold">
                        <td colspan="2">Tổng Vốn chủ sở hữu</td>
                        <td class="text-end">@Model.TotalEquity.ToString("N0")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card bg-light">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Tổng Tài sản:</strong> @Model.TotalAssets.ToString("N0")
                </div>
                <div class="col-md-4">
                    <strong>Tổng Nợ + Vốn:</strong> @(Model.TotalLiabilities + Model.TotalEquity).ToString("N0")
                </div>
                <div class="col-md-4">
                    @if (Model.IsBalanced)
                    {
                        <span class="badge bg-success">Báo cáo cân bằng</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Báo cáo không cân bằng</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Reports" asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>
