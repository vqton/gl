@model GL.Domain.Entities.IncomeStatementReport
@{
    ViewData["Title"] = "Kết quả hoạt động kinh doanh";
}

<div class="container mt-4">
    <h1>Kết quả hoạt động kinh doanh (BCKQHĐKD)</h1>
    <p class="text-muted">Kỳ báo cáo: @ViewBag.PeriodCode - Ngày lập: @ViewBag.ReportDate</p>
    <hr />
    
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Doanh thu</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên tài khoản</th>
                        <th class="text-end">Số tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var revenue in Model.Revenues)
                    {
                        <tr>
                            <td>@revenue.Code</td>
                            <td>@revenue.Name</td>
                            <td class="text-end">@revenue.Amount.ToString("N0")</td>
                        </tr>
                    }
                    <tr class="table-success fw-bold">
                        <td colspan="2">Tổng Doanh thu</td>
                        <td class="text-end">@Model.TotalRevenue.ToString("N0")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Chi phí</h5>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tên tài khoản</th>
                        <th class="text-end">Số tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var expense in Model.Expenses)
                    {
                        <tr>
                            <td>@expense.Code</td>
                            <td>@expense.Name</td>
                            <td class="text-end">@expense.Amount.ToString("N0")</td>
                        </tr>
                    }
                    <tr class="table-danger fw-bold">
                        <td colspan="2">Tổng Chi phí</td>
                        <td class="text-end">@Model.TotalExpenses.ToString("N0")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card bg-light">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Tổng Doanh thu:</strong> @Model.TotalRevenue.ToString("N0")
                </div>
                <div class="col-md-4">
                    <strong>Tổng Chi phí:</strong> @Model.TotalExpenses.ToString("N0")
                </div>
                <div class="col-md-4">
                    @if (Model.NetProfit >= 0)
                    {
                        <span class="badge bg-success">Lợi nhuận: @Model.NetProfit.ToString("N0")</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Lỗ: @Math.Abs(Model.NetProfit).ToString("N0")</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-controller="Reports" asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>
