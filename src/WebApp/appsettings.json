{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CloudSettings": {
    "DeploymentMode": "OnPremise",
    "EnableSwagger": true,
    "BaseCurrency": "VND",
    "SupportedCurrencies": ["USD", "EUR", "JPY", "CNY", "AUD"],
    "DefaultExchangeRateProvider": "Vietcombank"
  },
  "DatabaseProvider": "MariaDB",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=gl_accounting;User=root;Password=your_password; sslmode=none;CharSet=utf8mb4;",
    "PostgreSQL": "Host=localhost;Port=5432;Database=gl_accounting;Username=postgres;Password=your_password;",
    "SqlServer": "Server=localhost,1433;Database=GL_Accounting;User=sa;Password=YourPassword123!;TrustServerCertificate=True;",
    "Sqlite": "Data Source=gl.db"
  },
  "Database": {
    "AutoMigrate": true,
    "SeedCOA": true
  }
}
